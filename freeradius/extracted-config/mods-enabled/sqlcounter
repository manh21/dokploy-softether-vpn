sqlcounter uptimelimit {
    sql_module_instance = sql
    dialect = "postgresql"
    counter_name = Max-All-Session-Time
    check_name = Max-All-Session
    key = User-Name
    reset = never
    query = "SELECT COALESCE(SUM(AcctSessionTime), 0) FROM radacct WHERE UserName='%{${key}}'"
}
