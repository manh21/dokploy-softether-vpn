sqlcounter accessperiod {
    sql_module_instance = sql
    dialect = "postgresql"
    counter_name = Max-Access-Period-Time
    check_name = Access-Period
    key = User-Name
    reset = never
    query = "SELECT EXTRACT(EPOCH FROM NOW())::bigint - EXTRACT(EPOCH FROM MIN(AcctStartTime))::bigint FROM radacct WHERE UserName='%{${key}}'"
}

